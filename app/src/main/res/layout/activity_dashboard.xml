<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Omni-Rescue"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Service is stopped"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <ToggleButton
        android:id="@+id/toggle_service"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:textOn="Stop Listening"
        android:textOff="Start Listening"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_stop_alarm"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Stop Alarm"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/sensitivity_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sensitivity: 70%"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <SeekBar
        android:id="@+id/sensitivity_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="70"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Higher sensitivity = more detections. Lower = fewer false positives."
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/score_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Live score: --"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#757575"
        android:layout_marginTop="24dp"
        android:padding="12dp"
        android:background="#F5F5F5"/>

</LinearLayout>