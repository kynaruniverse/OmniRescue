<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <EditText
        android:id="@+id/etPhraseName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Phrase name (e.g., 'Where are you?')"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnRecordPhrase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Record Phrase"/>

    <TextView
        android:id="@+id/tvRecordStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Press record and say your phrase clearly"
        android:textAlignment="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>
