<resources>
    <style name="Theme.OmniRescue" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/rescue_red</item>
        <item name="colorPrimaryVariant">@color/rescue_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/rescue_orange</item>
        <item name="colorSecondaryVariant">@color/rescue_orange</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/rescue_red_dark</item>
    </style>

    <style name="Theme.OmniRescue.NoActionBar" parent="Theme.OmniRescue">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>